        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are a lead qualification specialist. Analyze this inbound lead and return ONLY a JSON object — no other text.\\n\\nLead info:\\nName: {{ $json.name }}\\nBusiness: {{ $json.business }}\\nMessage: {{ $json.message }}\\nSource: {{ $json.source }}\\n\\nReturn this exact JSON structure:\\n{\\n  \\\"score\\\": <integer 1-10>,\\n  \\\"tier\\\": <\\\"hot\\\" | \\\"warm\\\" | \\\"cold\\\">,\\n  \\\"reason\\\": <one sentence explaining the score>,\\n  \\\"suggested_action\\\": <one clear next step>\\n}\\n\\nScoring guide:\\n8-10 = Hot\\n5-7 = Warm\\n1-4 = Cold\"\n    }\n  ]\n}",
        "options": {}
      },

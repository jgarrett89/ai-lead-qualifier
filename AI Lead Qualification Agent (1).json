    {
      "parameters": {
        "jsCode": "const claudeResponse = $input.item.json.content[0].text;\n\nlet qualification;\ntry {\n  const clean = claudeResponse.replace(/```json\\n?|\\n?```/g, '').trim();\n  qualification = JSON.parse(clean);\n} catch (e) {\n  const match = claudeResponse.match(/\\{[\\s\\S]*\\}/);\n  qualification = JSON.parse(match[0]);\n}\n\nreturn {\n  json: {\n    name: $('Edit Fields').item.json.name,\n    email: $('Edit Fields').item.json.email,\n    business: $('Edit Fields').item.json.business,\n    message: $('Edit Fields').item.json.message,\n    source: $('Edit Fields').item.json.source,\n    timestamp: $('Edit Fields').item.json.timestamp,\n    score: qualification.score,\n    tier: qualification.tier,\n    reason: qualification.reason,\n    suggested_action: qualification.suggested_action\n  }\n};"
